[user]
	email = lighttiger2505@gmail.com
	name = lighttiger2505
[ghq]
	root = ~/src
[core]
	excludesfile = ~/.gitignore_global
[merge]
	tool = vimdiff
	ff = false
[diff]
	tool = vimdiff
[difftool "vimdiff"]
	cmd = "nvim -R -d -c \"wincmd l\" -d \"$LOCAL\" \"$REMOTE\""
[mergetool "vimdiff"]
	cmd = "nvim -d -c \"4wincmd w | wincmd J\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"  \"$MERGED\""
[difftool]
	prompt = true
[mergetool]
	prompt = true
[pull]
	ff = only
	rebase = true
[branch "master"]
	rebase = true
[branch "develop"]
	rebase = true
[includeIf "gitdir:~/src/github.com/"]
	path = ~/.gitconfig-private
[includeIf "gitdir:~/src/github.com/MobilityTechnologies/"]
	path = ~/.gitconfig-work
[commit]
	template = ~/.gitmessage.txt
	verbose = true
[push]
	autoSetupRemote = true
[rerere]
	enabled = true
